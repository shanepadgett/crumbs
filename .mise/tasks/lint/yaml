#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$SCRIPT_DIR"
while [[ "$ROOT" != "/" && ! -f "$ROOT/.mise/tasks/lib/scaffold.sh" ]]; do
  ROOT="$(dirname "$ROOT")"
done
source "$ROOT/.mise/tasks/lib/scaffold.sh"

run_filtered "lint yaml" "lint yaml failed" uvx yamllint==1.9.0 --config-file .config/yamllint .
