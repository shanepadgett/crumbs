{
  "$schema": "../../schemas/crumbs.schema.json",
  "extensions": {
    "caveman": {
      "enabled": true,
      "powers": ["improve", "architecture", "typescript"],
      "additionalContext": {
        "all": ["AGENTS.md", ".agents/instructions/working-plans.md"],
        "powers": {}
      }
    },
    "quietMiseTask": {
      "globalExcludeGlobs": ["external/**", "docs/_hidden/**"],
      "configs": [
        {
          "name": "config",
          "task": "check:config",
          "trackedExtensions": [".json", ".toml"]
        },
        {
          "enabled": true,
          "name": "ts",
          "task": "check:ts",
          "trackedExtensions": [".js", ".jsx", ".ts", ".tsx"]
        },
        {
          "enabled": true,
          "name": "markdown",
          "task": "check:markdown",
          "trackedExtensions": [".md"]
        },
        {
          "enabled": true,
          "name": "yaml",
          "task": "check:yaml",
          "trackedExtensions": [".yml", ".yaml"]
        }
      ]
    }
  }
}
