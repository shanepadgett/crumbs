{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crumbs.dev/schemas/crumbs.schema.json",
  "title": "Crumbs Configuration",
  "description": "Configuration for the Crumbs package and its extensions.",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional schema reference used by editors for validation and autocomplete."
    },
    "tools": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "properties": {
        "quietMiseTask": {
          "$ref": "#/$defs/quietMiseTaskConfig"
        },
        "statusLine": {
          "$ref": "#/$defs/statusLineConfig"
        },
        "codexCompat": {
          "$ref": "#/$defs/codexCompatConfig"
        },
        "guardian": {
          "$ref": "#/$defs/guardianConfig"
        },
        "commit": {
          "$ref": "#/$defs/commitConfig"
        },
        "caveman": {
          "$ref": "#/$defs/cavemanConfig"
        },
        "mcp": {
          "$ref": "#/$defs/mcpConfig"
        },
        "mcpDirect": {
          "$ref": "#/$defs/mcpConfig"
        }
      },
      "additionalProperties": true
    },
    "ui": {
      "type": "object",
      "additionalProperties": true
    },
    "experimental": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "quietMiseTaskConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the validator without removing its config."
        },
        "task": {
          "type": "string",
          "minLength": 1,
          "default": "check",
          "description": "mise task name to run when tracked file extensions change."
        },
        "trackedExtensions": {
          "type": "array",
          "description": "File extensions that should trigger the task. Examples: .swift, .ts, .tsx, .js, .jsx, .java.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "globalExcludeGlobs": {
          "type": "array",
          "description": "Path globs, relative to the repo root, excluded from every quiet mise task config. Use for repo-specific generated, vendored, or cache folders. Built-in ignored directories already include .build, .cache, .git, .gradle, .mypy_cache, .pi, .pytest_cache, .ruff_cache, .swiftpm, .tox, .venv, DerivedData, __pycache__, build, coverage, dist, node_modules, out, target, tmp, venv, and vendor.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "includeGlobs": {
          "type": "array",
          "description": "Path globs, relative to the repo root, that this legacy single-task config may track. When present, all other paths are ignored before per-config excludeGlobs are applied.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "excludeGlobs": {
          "type": "array",
          "description": "Extra path globs, relative to the repo root, excluded from this legacy single-task config after globalExcludeGlobs and includeGlobs are applied.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "configs": {
          "type": "array",
          "description": "Multiple mise task configs. When present, these entries replace the legacy single-task fields above.",
          "items": {
            "$ref": "#/$defs/quietMiseTaskEntry"
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "quietMiseTaskEntry": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Optional display label for this task config. Defaults to task name."
        },
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the validator without removing its config."
        },
        "task": {
          "type": "string",
          "minLength": 1,
          "default": "check",
          "description": "mise task name to run when tracked file extensions change."
        },
        "trackedExtensions": {
          "type": "array",
          "description": "File extensions that should trigger the task. Examples: .swift, .ts, .tsx, .js, .jsx, .java.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "includeGlobs": {
          "type": "array",
          "description": "Path globs, relative to the repo root, that this task config may track. When present, all other paths are ignored before excludeGlobs are applied. globalExcludeGlobs still wins and cannot be rescued by includeGlobs.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "excludeGlobs": {
          "type": "array",
          "description": "Extra path globs, relative to the repo root, excluded from this task config after globalExcludeGlobs and includeGlobs are applied.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "statusLineConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the status line footer by default."
        }
      },
      "additionalProperties": false
    },
    "codexCompatConfig": {
      "type": "object",
      "properties": {
        "fast": {
          "type": "boolean",
          "default": false,
          "description": "Enable OpenAI/OpenAI Codex priority service tier for supported requests."
        }
      },
      "additionalProperties": false
    },
    "guardianAction": {
      "type": "string",
      "enum": ["allow", "prompt", "autoApprove", "block"]
    },
    "guardianConfig": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["off", "gate"],
          "default": "gate",
          "description": "Enable or disable the guardian permission gate."
        },
        "ignoreTools": {
          "type": "array",
          "description": "Tool names the gate always allows. When provided, this replaces the built-in default list.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [
            "read",
            "grep",
            "find",
            "ls",
            "websearch",
            "webfetch",
            "codesearch",
            "view_image",
            "subagent"
          ]
        },
        "bash": {
          "type": "object",
          "properties": {
            "defaultAction": {
              "$ref": "#/$defs/guardianAction",
              "default": "autoApprove",
              "description": "Action for bash commands that match no explicit rule."
            },
            "rules": {
              "type": "array",
              "description": "Ordered shell-style glob rules for bash commands. First matching rule wins. When provided, this replaces the built-in default list.",
              "items": {
                "type": "object",
                "properties": {
                  "match": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Shell-style glob matched against normalized command text. Use * for any characters."
                  },
                  "action": {
                    "$ref": "#/$defs/guardianAction"
                  }
                },
                "required": ["match", "action"],
                "additionalProperties": false
              },
              "default": [
                { "match": ":(){*|*:", "action": "block" },
                { "match": "mkfs*", "action": "block" },
                { "match": "dd *of=/dev/*", "action": "block" },
                { "match": "*> /dev/sd*", "action": "block" },
                { "match": "*> /dev/nvme*", "action": "block" },
                { "match": "*> /dev/disk*", "action": "block" },
                { "match": "rm -rf /", "action": "block" },
                { "match": "rm -fr /", "action": "block" },
                { "match": "sudo *", "action": "prompt" },
                { "match": "chmod *777*", "action": "prompt" },
                { "match": "chown *777*", "action": "prompt" },
                { "match": "git push *--force*", "action": "prompt" },
                { "match": "curl *| sh*", "action": "prompt" },
                { "match": "curl *| bash*", "action": "prompt" },
                { "match": "wget *| sh*", "action": "prompt" },
                { "match": "wget *| bash*", "action": "prompt" },
                { "match": "*> /etc/*", "action": "prompt" },
                { "match": "rm -r *", "action": "prompt" },
                { "match": "rm -rf *", "action": "prompt" },
                { "match": "rm -fr *", "action": "prompt" }
              ]
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "mutation": {
          "type": "object",
          "properties": {
            "defaultAction": {
              "$ref": "#/$defs/guardianAction",
              "default": "allow",
              "description": "Action for workspace file mutations that match no explicit rule."
            },
            "rules": {
              "type": "array",
              "description": "Ordered path glob rules for file mutations. First matching rule wins. When provided, this replaces the built-in default list.",
              "items": {
                "type": "object",
                "properties": {
                  "paths": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    },
                    "minItems": 1
                  },
                  "action": {
                    "$ref": "#/$defs/guardianAction"
                  }
                },
                "required": ["paths", "action"],
                "additionalProperties": false
              },
              "default": [{ "paths": [".git", ".git/**"], "action": "block" }]
            },
            "allowOutsideWorkspace": {
              "type": "boolean",
              "default": false,
              "description": "Allow writes whose canonical target is outside the current workspace."
            },
            "maxBytes": {
              "type": "number",
              "minimum": 0,
              "description": "Prompt before write/apply_patch mutations larger than this many bytes."
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "unknownToolAction": {
          "type": "string",
          "$ref": "#/$defs/guardianAction",
          "default": "prompt",
          "description": "Action for non-built-in tools the gate does not recognize."
        },
        "autoApprove": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Enable LLM auto approval for eligible requests."
            },
            "model": {
              "type": "string",
              "description": "Auto approval model as provider/id. Defaults to the active session model."
            },
            "reviewBash": {
              "type": "boolean",
              "default": true,
              "description": "Send bash commands with autoApprove action to model review when enabled."
            },
            "reviewMutations": {
              "type": "boolean",
              "default": true,
              "description": "Send file mutations with autoApprove action to model review when enabled."
            },
            "timeoutMs": {
              "type": "number",
              "minimum": 1,
              "default": 15000,
              "description": "Maximum guardian review time in milliseconds."
            },
            "maxTokens": {
              "type": "number",
              "minimum": 1,
              "default": 256,
              "description": "Maximum guardian response tokens."
            }
          },
          "additionalProperties": false,
          "default": {}
        }
      },
      "additionalProperties": false
    },
    "commitConfig": {
      "type": "object",
      "properties": {
        "allowedTypes": {
          "type": "array",
          "description": "Conventional commit types the /commit agent may use. Custom repo-specific types are allowed. When provided, this replaces the built-in default list.",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z][A-Za-z0-9-]*$"
          },
          "uniqueItems": true,
          "minItems": 1,
          "default": [
            "feat",
            "fix",
            "docs",
            "style",
            "refactor",
            "perf",
            "test",
            "build",
            "ci",
            "chore",
            "revert"
          ]
        },
        "allowBreakingChangeMarker": {
          "type": "boolean",
          "default": true,
          "description": "Allow the /commit agent to use the Conventional Commits ! marker, such as feat! or fix!, only for true breaking changes."
        }
      },
      "additionalProperties": false
    },
    "cavemanConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Caveman system prompt mode by default."
        },
        "powers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["improve", "design", "architecture", "swiftui", "typescript"]
          },
          "uniqueItems": true,
          "default": [],
          "description": "Optional Caveman powers. improve adds Pi self-improvement guidance. design adds UX and interface-shaping guidance. architecture adds stronger ownership and abstraction judgment. swiftui adds modern SwiftUI guidance. typescript adds stronger TypeScript guidance."
        },
        "additionalContext": {
          "type": "object",
          "description": "Additional context files whose contents are injected into the Caveman system prompt.",
          "properties": {
            "all": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true,
              "default": [],
              "description": "Files injected whenever Caveman is enabled. Relative paths resolve from project root."
            },
            "powers": {
              "type": "object",
              "description": "Files injected only when matching Caveman power is active.",
              "properties": {
                "improve": {
                  "$ref": "#/$defs/cavemanAdditionalContextPathList"
                },
                "design": {
                  "$ref": "#/$defs/cavemanAdditionalContextPathList"
                },
                "architecture": {
                  "$ref": "#/$defs/cavemanAdditionalContextPathList"
                },
                "swiftui": {
                  "$ref": "#/$defs/cavemanAdditionalContextPathList"
                },
                "typescript": {
                  "$ref": "#/$defs/cavemanAdditionalContextPathList"
                }
              },
              "additionalProperties": false,
              "default": {}
            }
          },
          "additionalProperties": false,
          "default": {
            "all": [],
            "powers": {}
          }
        }
      },
      "additionalProperties": false
    },
    "cavemanAdditionalContextPathList": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "default": []
    },
    "mcpConfig": {
      "type": "object",
      "properties": {
        "mcpServers": {
          "type": "object",
          "description": "Named MCP server entries.",
          "additionalProperties": {
            "$ref": "#/$defs/mcpServerConfig"
          },
          "default": {}
        }
      },
      "additionalProperties": false,
      "default": {
        "mcpServers": {}
      }
    },
    "mcpServerConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable this server entry."
        },
        "requiresCavemanPower": {
          "type": "string",
          "enum": ["improve", "design", "architecture", "swiftui", "typescript"],
          "description": "Enable this server only when Caveman is enabled and this power is active."
        },
        "lifecycle": {
          "type": "string",
          "enum": ["lazy", "eager"],
          "default": "lazy",
          "description": "Server startup policy."
        },
        "command": {
          "type": "string",
          "description": "Stdio mode executable command."
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Stdio mode command arguments."
        },
        "cwd": {
          "type": "string",
          "description": "Optional working directory for stdio mode."
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Optional environment variables for stdio mode."
        },
        "url": {
          "type": "string",
          "description": "HTTP mode server URL."
        },
        "serverUrl": {
          "type": "string",
          "description": "Legacy alias for url."
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Optional HTTP headers."
        },
        "bearerToken": {
          "type": "string",
          "description": "Optional static bearer token for HTTP mode."
        },
        "bearerTokenEnv": {
          "type": "string",
          "description": "Environment variable name to read bearer token from."
        }
      },
      "additionalProperties": true
    }
  },
  "examples": [
    {
      "$schema": "https://crumbs.dev/schemas/crumbs.schema.json",
      "extensions": {
        "quietMiseTask": {
          "enabled": true,
          "configs": [
            {
              "name": "swift",
              "task": "check:swift",
              "trackedExtensions": [".swift"],
              "excludeGlobs": ["external/**"]
            },
            {
              "name": "web",
              "task": "check:web",
              "trackedExtensions": [".ts", ".tsx", ".js", ".jsx"]
            }
          ]
        }
      }
    }
  ]
}
