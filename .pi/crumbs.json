{
  "$schema": "../schemas/crumbs.schema.json",
  "defaultPolicy": "ask",
  "onNoUi": "deny",
  "allow": [
    {
      "match": "regex",
      "value": "^mise\\s+run\\s+(?:format|lint|typecheck|check)$"
    },
    {
      "match": "regex",
      "value": "^mkdir\\s+-p\\s+(?:(?:extensions|shared)(?:/[A-Za-z0-9._-]+)+)(?:\\s+(?:(?:extensions|shared)(?:/[A-Za-z0-9._-]+)+))*$"
    },
    {
      "match": "regex",
      "value": "^mv\\s+(?:(?:extensions|shared)(?:/[A-Za-z0-9._*-]+)+)\\s+(?:(?:extensions|shared)(?:/[A-Za-z0-9._*-]+)+)/?$"
    },
    {
      "match": "regex",
      "value": "^rmdir\\s+(?:(?:extensions|shared)(?:/[A-Za-z0-9._-]+)*)(?:\\s+(?:(?:extensions|shared)(?:/[A-Za-z0-9._-]+)*))*$"
    },
    {
      "match": "prefix",
      "value": "git show HEAD:"
    },
    {
      "match": "exact",
      "value": "mise tasks"
    }
  ],
  "deny": [],
  "fileGuard": {
    "defaults": {
      "onNoUi": "deny"
    },
    "paths": {
      "hardBlocked": ["docs/_hidden/", ".env"],
      "policyFiles": [".pi/crumbs.json"]
    },
    "rules": {
      "block": ["@hardBlocked"],
      "gate": {
        "mutate": [
          {
            "match": "@policyFiles",
            "reason": "Editing crumbs policy requires approval.",
            "onNoUi": "deny"
          }
        ]
      }
    },
    "injectPromptReminder": true
  }
}
